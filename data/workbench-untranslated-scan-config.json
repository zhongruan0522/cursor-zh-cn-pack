        "Cursor Account",
        "Plan \\u0026 Usage",
        "Rules, Skills, Subagents",
        "Tools \\u0026 MCPs",
        "Indexing \\u0026 Docs",
        "Import Settings from VS Code",
        "Reset \"Don't Ask Again\" Dialogs"
      ]
    },
    {
      "id": "settings-dom",
      "label": "设置页 DOM",
      "patterns": [
        "cursor-settings-cell-label",
        "cursor-settings-cell-description",
        "settings-search",
        "settings-sidebar"
      ]
    },
    {
      "id": "settings-route",
      "label": "设置页路由",
